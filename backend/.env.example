# Copie ce fichier en ".env" et remplis les valeurs.

# Port du serveur
PORT=5000

# Connexion MongoDB
# Local : mongodb://127.0.0.1:27017/medibook
# Atlas : mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/medibook
MONGO_URI=mongodb://127.0.0.1:27017/medibook

# Clé secrète pour signer les tokens JWT (mets une longue chaîne aléatoire)
JWT_SECRET=change_moi_par_une_longue_chaine_secrete

# URL du frontend autorisée par CORS
CLIENT_URL=http://localhost:5173
